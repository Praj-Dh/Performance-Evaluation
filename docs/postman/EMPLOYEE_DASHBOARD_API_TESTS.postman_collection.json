    {
      "name": "Test 3 - Recent Activity View All API coverage",
      "description": "Verifies collaboration history records expose the expected fields for list/table rendering.",
      "item": [
        {
          "name": "3.1 Validate collaboration history list and sort order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/collaboration-log.php"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "const events = Array.isArray(data.events) ? data.events : [];",
                  "pm.test('History endpoint returns an array', function () {",
                  "  pm.expect(Array.isArray(data.events)).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Seeded employee has collaboration history records', function () {",
                  "  pm.expect(events.length).to.be.greaterThan(0);",
                  "});",
                  "",
                  "events.forEach(function (event, idx) {",
                  "  pm.test(`History record ${idx + 1} includes display fields`, function () {",
                  "    pm.expect(event.title).to.be.a('string');",
                  "    pm.expect(event.event_type).to.be.a('string');",
                  "    pm.expect(event.event_date).to.be.a('string');",
                  "    pm.expect(event.description !== undefined).to.eql(true);",
                  "  });",
                  "});",
                  "",
                  "let sorted = true;",
                  "for (let i = 1; i < events.length; i += 1) {",
                  "  const prev = events[i - 1];",
                  "  const curr = events[i];",
                  "  const prevDate = prev.event_date || '';",
                  "  const currDate = curr.event_date || '';",
                  "",
                  "  if (prevDate < currDate) {",
                  "    sorted = false;",
                  "    break;",
                  "  }",
                  "",
                  "  if (prevDate === currDate) {",
                  "    const prevCreated = Date.parse(prev.created_at || '1970-01-01T00:00:00Z');",
                  "    const currCreated = Date.parse(curr.created_at || '1970-01-01T00:00:00Z');",
                  "    if (prevCreated < currCreated) {",
                  "      sorted = false;",
                  "      break;",
                  "    }",
                  "  }",
                  "}",
                  "",
                  "pm.test('Records are sorted by event_date desc then created_at desc', function () {",
                  "  pm.expect(sorted).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Test 4 - This Week at a Glance metric quality",
      "description": "Computes week-over-week activity metrics from API data and ensures numeric values are stable.",
      "item": [
        {
          "name": "4.1 Compute weekly activity and comparison indicator",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/collaboration-log.php"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "const events = Array.isArray(data.events) ? data.events : [];",
                  "",
                  "function startOfWeekUtc(dateObj) {",
                  "  const d = new Date(Date.UTC(dateObj.getUTCFullYear(), dateObj.getUTCMonth(), dateObj.getUTCDate()));",
                  "  const day = d.getUTCDay();",
                  "  const diffToMonday = (day + 6) % 7;",
                  "  d.setUTCDate(d.getUTCDate() - diffToMonday);",
                  "  d.setUTCHours(0, 0, 0, 0);",
                  "  return d;",
                  "}",
                  "",
                  "const now = new Date();",
                  "const thisWeekStart = startOfWeekUtc(now);",
                  "const nextWeekStart = new Date(thisWeekStart);",
                  "nextWeekStart.setUTCDate(nextWeekStart.getUTCDate() + 7);",
                  "const prevWeekStart = new Date(thisWeekStart);",
                  "prevWeekStart.setUTCDate(prevWeekStart.getUTCDate() - 7);",
                  "",
                  "let thisWeekCount = 0;",
                  "let prevWeekCount = 0;",
                  "events.forEach(function (e) {",
                  "  if (e.status !== 'submitted' || !e.event_date) return;",
                  "  const d = new Date(`${e.event_date}T00:00:00Z`);",
                  "  if (d >= thisWeekStart && d < nextWeekStart) thisWeekCount += 1;",
                  "  else if (d >= prevWeekStart && d < thisWeekStart) prevWeekCount += 1;",
                  "});",
                  "",
                  "const pctChange = prevWeekCount === 0",
                  "  ? (thisWeekCount === 0 ? 0 : 100)",
                  "  : Math.round(((thisWeekCount - prevWeekCount) / prevWeekCount) * 100);",
                  "",
                  "pm.test('This week activity value is numeric and not NaN', function () {",
                  "  pm.expect(Number.isFinite(thisWeekCount)).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Comparison indicator is numeric and not NaN', function () {",
                  "  pm.expect(Number.isFinite(pctChange)).to.eql(true);",
                  "});",
                  "",
                  "pm.test('Computed values are non-negative counts', function () {",
                  "  pm.expect(thisWeekCount).to.be.at.least(0);",
                  "  pm.expect(prevWeekCount).to.be.at.least(0);",
                  "});",
                  "",
                  "pm.collectionVariables.set('this_week_count', String(thisWeekCount));",
                  "pm.collectionVariables.set('previous_week_count', String(prevWeekCount));",
                  "pm.collectionVariables.set('week_over_week_pct', String(pctChange));"
                ]
              }
            }
          ]
        }
      ]
    },
