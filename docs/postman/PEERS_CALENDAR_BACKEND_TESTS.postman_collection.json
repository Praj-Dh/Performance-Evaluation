    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "employee_email",
      "value": "morgan.lee.0@example.com"
    },
    {
      "key": "employee_password",
      "value": "Password123!"
    },
    {
      "key": "test_date",
      "value": "2026-03-18"
    },
    {
      "key": "test_month",
      "value": "2026-03"
    },
    {
      "key": "comment_text",
      "value": ""
    },
    {
      "key": "created_comment_id",
      "value": ""
    }
  ]
}
